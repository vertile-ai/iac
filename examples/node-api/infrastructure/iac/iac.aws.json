{
  "$schema": "../../../../schema/iac.schema.json",
  "version": 1,
  "project": {
    "key": "node-api",
    "name": "node-api"
  },
  "environments": [
    "development",
    "test",
    "uat",
    "nightly",
    "staging",
    "preview",
    "production"
  ],
  "providers": {
    "aws": {
      "region": "us-east-1",
      "defaultTags": {
        "Example": "node-api",
        "Runtime": "node"
      },
      "resources": [
        {
          "type": "aws_cloudwatch_log_group",
          "name": "api",
          "values": {
            "name": "/examples/node-api",
            "retention_in_days": 7
          }
        }
      ],
      "deployments": {
        "dev": {
          "environment": "development",
          "region": "us-east-1",
          "profile": "node-api-dev",
          "tags": {
            "Stage": "dev"
          }
        },
        "uat": {
          "environment": "uat",
          "region": "us-east-1",
          "profile": "node-api-uat",
          "tags": {
            "Stage": "uat"
          }
        },
        "nightly": {
          "environment": "nightly",
          "region": "us-east-1",
          "profile": "node-api-nightly",
          "tags": {
            "Stage": "nightly"
          }
        },
        "prod": {
          "environment": "production",
          "region": "us-east-1",
          "profile": "node-api-prod",
          "tags": {
            "Stage": "prod"
          }
        }
      }
    }
  },
  "apps": [
    {
      "key": "api",
      "name": "node-api",
      "framework": "node",
      "rootDirectory": "."
    }
  ],
  "queues": [
    {
      "key": "jobs",
      "providers": {
        "aws": {
          "visibilityTimeoutSeconds": 45
        }
      }
    }
  ],
  "sandboxes": [
    {
      "key": "api-runner",
      "providers": {
        "aws": {
          "instanceType": "t3.micro"
        }
      }
    }
  ],
  "env": {
    "environments": {
      "development": {
        "files": [
          ".env.development"
        ]
      },
      "test": {
        "files": [
          ".env.test"
        ]
      },
      "uat": {
        "files": [
          ".env.uat"
        ]
      },
      "nightly": {
        "files": [
          ".env.nightly"
        ]
      },
      "staging": {
        "files": [
          ".env.staging"
        ]
      },
      "production": {
        "files": [
          ".env.production"
        ]
      }
    }
  }
}
