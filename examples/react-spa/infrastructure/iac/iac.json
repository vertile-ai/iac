{
  "$schema": "../../../../schema/iac.schema.json",
  "version": 1,
  "project": {
    "key": "react-spa",
    "name": "react-spa"
  },
  "environments": {
    "development": {
      "files": [
        ".env.development"
      ]
    },
    "test": {
      "files": [
        ".env.test"
      ]
    },
    "uat": {
      "files": [
        ".env.uat"
      ]
    },
    "nightly": {
      "files": [
        ".env.nightly"
      ]
    },
    "staging": {
      "files": [
        ".env.staging"
      ]
    },
    "preview": {},
    "production": {
      "files": [
        ".env.production"
      ]
    }
  },
  "providers": {
    "vercel": {
      "teamSlug": "example-team"
    },
    "aws": {
      "region": "us-east-1",
      "deployments": {
        "dev": {
          "environment": "development",
          "region": "us-east-1",
          "profile": "react-spa-dev",
          "tags": {
            "Stage": "dev"
          }
        },
        "uat": {
          "environment": "uat",
          "region": "us-east-1",
          "profile": "react-spa-uat",
          "tags": {
            "Stage": "uat"
          }
        },
        "nightly": {
          "environment": "nightly",
          "region": "us-east-1",
          "profile": "react-spa-nightly",
          "tags": {
            "Stage": "nightly"
          }
        },
        "prod": {
          "environment": "production",
          "region": "us-east-1",
          "profile": "react-spa-prod",
          "tags": {
            "Stage": "prod"
          }
        }
      }
    }
  },
  "apps": [
    {
      "key": "web",
      "name": "react-spa",
      "framework": "vite",
      "rootDirectory": ".",
      "outputDir": "dist",
      "domains": [
        "react-spa.example.com"
      ]
    }
  ],
  "objectStorage": [
    {
      "key": "assets",
      "visibility": "public"
    }
  ]
}
