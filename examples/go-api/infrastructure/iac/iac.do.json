{
  "$schema": "../../../../schema/iac.schema.json",
  "version": 1,
  "project": {
    "key": "go-api",
    "name": "go-api"
  },
  "environments": [
    "development",
    "test",
    "uat",
    "nightly",
    "staging",
    "preview",
    "production"
  ],
  "providers": {
    "digitalocean": {
      "region": "nyc3",
      "resources": [
        {
          "type": "digitalocean_project",
          "name": "main",
          "values": {
            "name": "go-api"
          }
        }
      ]
    }
  },
  "apps": [
    {
      "key": "api",
      "name": "go-api",
      "framework": "go",
      "rootDirectory": "."
    }
  ],
  "queues": [
    {
      "key": "jobs"
    }
  ],
  "clusters": [
    {
      "key": "workers",
      "size": 2,
      "providers": {
        "digitalocean": {
          "nodes": 2,
          "sizeSlug": "s-1vcpu-1gb"
        }
      }
    }
  ],
  "env": {
    "environments": {
      "development": {
        "files": [
          ".env.development"
        ]
      },
      "test": {
        "files": [
          ".env.test"
        ]
      },
      "uat": {
        "files": [
          ".env.uat"
        ]
      },
      "nightly": {
        "files": [
          ".env.nightly"
        ]
      },
      "staging": {
        "files": [
          ".env.staging"
        ]
      },
      "production": {
        "files": [
          ".env.production"
        ]
      }
    }
  }
}
