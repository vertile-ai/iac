{
  "$schema": "../../../../schema/iac.schema.json",
  "version": 1,
  "project": {
    "key": "next-monorepo",
    "name": "next-monorepo"
  },
  "environments": {
    "development": {
      "files": [
        ".env.development"
      ]
    },
    "test": {
      "files": [
        ".env.test"
      ]
    },
    "uat": {
      "files": [
        ".env.uat"
      ]
    },
    "nightly": {
      "files": [
        ".env.nightly"
      ]
    },
    "staging": {
      "files": [
        ".env.staging"
      ]
    },
    "preview": {},
    "production": {
      "files": [
        ".env.production"
      ]
    }
  },
  "providers": {
    "digitalocean": {
      "region": "nyc3",
      "version": ">= 2.0.0",
      "resources": [
        {
          "type": "digitalocean_project",
          "name": "main",
          "values": {
            "name": "next-monorepo"
          }
        }
      ]
    }
  },
  "apps": [
    {
      "key": "web",
      "name": "next-monorepo-web",
      "framework": "nextjs",
      "rootDirectory": "apps/web"
    },
    {
      "key": "admin",
      "name": "next-monorepo-admin",
      "framework": "nextjs",
      "rootDirectory": "apps/admin"
    }
  ],
  "objectStorage": [
    {
      "key": "uploads",
      "visibility": "private",
      "providers": {
        "digitalocean": {
          "name": "next-monorepo-uploads",
          "acl": "private",
          "region": "nyc3"
        }
      }
    }
  ],
  "databases": [
    {
      "key": "appdb",
      "engine": "postgres",
      "providers": {
        "digitalocean": {
          "engine": "pg",
          "version": "16",
          "size": "db-s-1vcpu-1gb",
          "nodeCount": 1
        }
      }
    }
  ],
  "sandboxes": [
    {
      "key": "runner",
      "providers": {
        "digitalocean": {
          "sizeSlug": "s-1vcpu-1gb"
        }
      }
    }
  ],
  "clusters": [
    {
      "key": "workers",
      "size": 2,
      "providers": {
        "digitalocean": {
          "nodes": 2,
          "sizeSlug": "s-1vcpu-2gb"
        }
      }
    }
  ]
}
