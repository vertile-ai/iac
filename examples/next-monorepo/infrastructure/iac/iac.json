{
  "$schema": "../../../../schema/iac.schema.json",
  "version": 1,
  "project": {
    "key": "next-monorepo",
    "name": "next-monorepo"
  },
  "environments": {
    "development": {
      "files": [
        ".env.development"
      ]
    },
    "test": {
      "files": [
        ".env.test"
      ]
    },
    "uat": {
      "files": [
        ".env.uat"
      ]
    },
    "nightly": {
      "files": [
        ".env.nightly"
      ]
    },
    "staging": {
      "files": [
        ".env.staging"
      ]
    },
    "preview": {},
    "production": {
      "files": [
        ".env.production"
      ]
    }
  },
  "providers": {
    "vercel": {
      "teamSlug": "vertile-ai",
      "projectDefaults": {
        "nodeVersion": "20.x",
        "enableAffectedProjectsDeployments": true
      },
      "resources": [
        {
          "type": "vercel_project_environment_variable",
          "name": "example_escape_hatch",
          "values": {
            "project_id": "prj_next_monorepo_placeholder",
            "key": "ESCAPE_HATCH_EXAMPLE",
            "value": "configured-through-provider-resource",
            "target": [
              "preview"
            ]
          }
        }
      ]
    },
    "aws": {
      "region": "us-east-1",
      "defaultTags": {
        "Owner": "vertile-ai",
        "Fixture": "next-monorepo"
      },
      "resources": [
        {
          "type": "aws_sns_topic",
          "name": "events",
          "values": {
            "name": "next-monorepo-events"
          }
        }
      ],
      "deployments": {
        "dev": {
          "environment": "development",
          "region": "us-east-1",
          "profile": "next-monorepo-dev",
          "tags": {
            "Stage": "dev"
          }
        },
        "uat": {
          "environment": "uat",
          "region": "us-east-1",
          "profile": "next-monorepo-uat",
          "tags": {
            "Stage": "uat"
          }
        },
        "nightly": {
          "environment": "nightly",
          "region": "us-east-1",
          "profile": "next-monorepo-nightly",
          "tags": {
            "Stage": "nightly"
          }
        },
        "prod": {
          "environment": "production",
          "region": "us-east-1",
          "profile": "next-monorepo-prod",
          "tags": {
            "Stage": "prod"
          }
        }
      }
    },
    "digitalocean": {
      "region": "nyc3",
      "version": ">= 2.0.0",
      "resources": [
        {
          "type": "digitalocean_project",
          "name": "main",
          "values": {
            "name": "next-monorepo"
          }
        }
      ]
    }
  },
  "env": {
    "sourceDir": "infrastructure",
    "sync": {
      "apps": [
        "web",
        "admin"
      ],
      "sharedKey": "shared"
    },
    "metadata": {
      "shared": {
        "variables": [
          {
            "key": "NEXT_PUBLIC_APP_ENV",
            "example": "development",
            "encrypted": false,
            "browser": true
          },
          {
            "key": "NEXT_PUBLIC_API_BASE_URL",
            "example": "http://localhost:3000",
            "encrypted": false,
            "browser": true
          },
          {
            "key": "ADMIN_NEXT_PUBLIC_APP_ENV",
            "example": "development",
            "encrypted": false,
            "browser": true
          },
          {
            "key": "ADMIN_NEXT_PUBLIC_API_BASE_URL",
            "example": "http://localhost:3001",
            "encrypted": false,
            "browser": true
          }
        ]
      },
      "web": {
        "variables": [
          {
            "key": "DATABASE_URL",
            "example": "postgres://user:password@localhost:5432/dynomic",
            "encrypted": true,
            "browser": false
          },
          {
            "key": "STRIPE_SECRET_KEY",
            "example": "stripe-test-placeholder",
            "encrypted": true,
            "browser": false
          }
        ]
      },
      "admin": {
        "variables": [
          {
            "key": "ADMIN_DATABASE_URL",
            "example": "postgres://user:password@localhost:5432/dynomic_admin",
            "encrypted": true,
            "browser": false
          },
          {
            "key": "ADMIN_SESSION_SECRET",
            "example": "admin-session-placeholder",
            "encrypted": true,
            "browser": false
          }
        ]
      }
    }
  },
  "apps": [
    {
      "key": "web",
      "id": "prj_next_monorepo_web_placeholder",
      "name": "next-monorepo-web",
      "framework": "nextjs",
      "rootDirectory": "apps/web",
      "nodeVersion": "20.x",
      "domains": [
        "next-monorepo.example.com",
        {
          "name": "preview.next-monorepo.example.com",
          "gitBranch": "preview"
        }
      ],
      "providers": {
        "vercel": {
          "enableAffectedProjectsDeployments": true
        }
      }
    },
    {
      "key": "admin",
      "id": "prj_next_monorepo_admin_placeholder",
      "name": "next-monorepo-admin",
      "framework": "nextjs",
      "rootDirectory": "apps/admin",
      "nodeVersion": "20.x",
      "domains": [
        "admin.next-monorepo.example.com",
        {
          "name": "admin-preview.next-monorepo.example.com",
          "gitBranch": "preview"
        }
      ],
      "env": {
        "sharedPrefix": "ADMIN_"
      }
    }
  ],
  "domains": [
    {
      "name": "www.next-monorepo.example.com",
      "app": "web"
    }
  ],
  "objectStorage": [
    {
      "key": "uploads",
      "visibility": "private",
      "providers": {
        "aws": {
          "bucket": "next-monorepo-production-uploads",
          "forceDestroy": true
        },
        "digitalocean": {
          "name": "next-monorepo-uploads",
          "acl": "private",
          "region": "nyc3"
        }
      }
    }
  ],
  "databases": [
    {
      "key": "appdb",
      "engine": "postgres",
      "providers": {
        "aws": {
          "engineVersion": "16",
          "instanceClass": "db.t4g.micro",
          "allocatedStorage": 20,
          "databaseName": "next_monorepo",
          "username": "next_monorepo",
          "skipFinalSnapshot": true
        },
        "digitalocean": {
          "engine": "pg",
          "version": "16",
          "size": "db-s-1vcpu-1gb",
          "nodeCount": 1
        }
      }
    }
  ],
  "queues": [
    {
      "key": "jobs",
      "kind": "fifo",
      "providers": {
        "aws": {
          "visibilityTimeoutSeconds": 60,
          "messageRetentionSeconds": 345600
        }
      }
    }
  ],
  "sandboxes": [
    {
      "key": "runner",
      "providers": {
        "aws": {
          "instanceType": "t3.micro"
        },
        "digitalocean": {
          "sizeSlug": "s-1vcpu-1gb"
        }
      }
    }
  ],
  "clusters": [
    {
      "key": "workers",
      "size": 2,
      "providers": {
        "aws": {
          "instanceType": "t3.small"
        },
        "digitalocean": {
          "nodes": 2,
          "sizeSlug": "s-1vcpu-2gb"
        }
      }
    }
  ]
}
