{
  "$schema": "../../../../schema/iac.schema.json",
  "version": 1,
  "project": {
    "key": "python-fastapi-api",
    "name": "python-fastapi-api"
  },
  "environments": {
    "development": {
      "files": [
        ".env.development"
      ]
    },
    "test": {
      "files": [
        ".env.test"
      ]
    },
    "uat": {
      "files": [
        ".env.uat"
      ]
    },
    "nightly": {
      "files": [
        ".env.nightly"
      ]
    },
    "staging": {
      "files": [
        ".env.staging"
      ]
    },
    "preview": {},
    "production": {
      "files": [
        ".env.production"
      ]
    }
  },
  "providers": {
    "aws": {
      "region": "us-east-1",
      "deployments": {
        "dev": {
          "environment": "development",
          "region": "us-east-1",
          "profile": "python-fastapi-api-dev",
          "tags": {
            "Stage": "dev"
          }
        },
        "uat": {
          "environment": "uat",
          "region": "us-east-1",
          "profile": "python-fastapi-api-uat",
          "tags": {
            "Stage": "uat"
          }
        },
        "nightly": {
          "environment": "nightly",
          "region": "us-east-1",
          "profile": "python-fastapi-api-nightly",
          "tags": {
            "Stage": "nightly"
          }
        },
        "prod": {
          "environment": "production",
          "region": "us-east-1",
          "profile": "python-fastapi-api-prod",
          "tags": {
            "Stage": "prod"
          }
        }
      }
    },
    "digitalocean": {
      "region": "nyc3"
    }
  },
  "apps": [
    {
      "key": "api",
      "name": "python-fastapi-api",
      "framework": "fastapi",
      "rootDirectory": "."
    }
  ],
  "databases": [
    {
      "key": "appdb",
      "engine": "postgres"
    }
  ],
  "clusters": [
    {
      "key": "workers",
      "size": 2
    }
  ]
}
