{
  "$schema": "../../../../schema/iac.schema.json",
  "version": 1,
  "project": {
    "key": "sveltekit-web",
    "name": "sveltekit-web"
  },
  "environments": [
    "development",
    "test",
    "uat",
    "nightly",
    "staging",
    "preview",
    "production"
  ],
  "providers": {
    "vercel": {
      "teamSlug": "example-team"
    },
    "digitalocean": {
      "region": "nyc3"
    }
  },
  "apps": [
    {
      "key": "web",
      "name": "sveltekit-web",
      "framework": "sveltekit",
      "rootDirectory": ".",
      "domains": [
        "sveltekit.example.com"
      ]
    }
  ],
  "databases": [
    {
      "key": "content",
      "engine": "postgres"
    }
  ],
  "env": {
    "environments": {
      "development": {
        "files": [
          ".env.development"
        ]
      },
      "test": {
        "files": [
          ".env.test"
        ]
      },
      "uat": {
        "files": [
          ".env.uat"
        ]
      },
      "nightly": {
        "files": [
          ".env.nightly"
        ]
      },
      "staging": {
        "files": [
          ".env.staging"
        ]
      },
      "production": {
        "files": [
          ".env.production"
        ]
      }
    }
  }
}
