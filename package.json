{
  "name": "@jazelly/iac",
  "version": "0.1.0",
  "description": "Private Jazelly infrastructure-as-code reconciliation tools.",
  "type": "module",
  "bin": {
    "jazelly-iac": "src/cli.mjs",
    "jazelly-iac-env": "src/provision-env.mjs",
    "jazelly-iac-projects": "src/reconcile-project-settings.mjs",
    "jazelly-iac-domains": "src/reconcile-project-domains.mjs"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.mjs",
    "env:dry-run": "node src/provision-env.mjs",
    "env:apply": "node src/provision-env.mjs --apply",
    "projects:dry-run": "node src/reconcile-project-settings.mjs",
    "projects:apply": "node src/reconcile-project-settings.mjs --apply",
    "domains:dry-run": "node src/reconcile-project-domains.mjs",
    "domains:apply": "node src/reconcile-project-domains.mjs --apply"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
